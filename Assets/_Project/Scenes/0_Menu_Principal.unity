      m_Calls: []
  m_text: "\nCONTROL LONGITUDINAL (Pedales)\r\n<color=#FFFF00><b>[ W ]</b></color>
    : Acelerar (Throttle)\r\n<color=#FFFF00><b>[ S ]</b></color> : Frenar (Brake)\r\n<color=#FFFF00><b>[
    Shift Izq ]</b></color> : Pedal de Embrague (Clutch)\n\n\r\nCONTROL LATERAL (Direcci\xF3n)\r\n<color=#FFFF00><b>[
    A ] / [ D ]</b></color> : Girar Volante (Steering)\r\nTRANSMISI\xD3N MANUAL\r\n<color=#FFFF00><b>[
    E ]</b></color> : Subir Marcha (Gear Up)\r\n<color=#FFFF00><b>[ Q ]</b></color>
    : Bajar Marcha (Gear Down)\r\nNota: Es obligatorio pisar el embrague para cambiar
    de marcha.\n\n\r\nSISTEMAS AUXILIARES\r\n<color=#FFFF00><b>[ R ]</b></color>
    : Arrancar Motor (En caso de calado)\r\n<color=#FFFF00><b>[ Z ]</b></color> :
    Intermitente Izquierdo\r\n<color=#FFFF00><b>[ X ]</b></color> : Intermitente
    Derecho\n\n\r\nINTERFAZ\r\n<color=#FFFF00><b>[ Esc ]</b></color> : Pausa / Salir\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
